# Path to SQLite database file
# On Railway: set to /data/veckis.db (after adding a Volume with mount /data)
# Locally: leave empty to use ./data/veckis.db
DATABASE_PATH=

# Secret for the cron endpoint (POST /api/topup)
# Set this to any random string, e.g.: openssl rand -hex 32
CRON_SECRET=change-me-to-a-random-string
